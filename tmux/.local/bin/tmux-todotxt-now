#!/usr/bin/env janet

(use judge)

(def max-length 80)
(def ellipsis "...")
(def todo-path (string (os/getenv "HOME") "/Library/Mobile Documents/com~apple~CloudDocs/todotxt/todo.txt"))

(defn read-from-file [file-path]
  (let [f (file/open file-path :r)
        content (file/read f :all)]
    (file/close f)
    content))

(defn find-priority-a-tasks [content]
  (when content
    (->> (string/split "\n" content)
         (filter |(string/has-prefix? "(A) " $))
         (map |(string/slice $ 4)))))

(defn find-priority-a-task [content]
  (first (find-priority-a-tasks content)))

(defn remove-project [text]
  (->> text
       (peg/replace ~(sequence " +" (thru :a+)) "")
       (string)))

(test (remove-project "hey") "hey")
(test (remove-project "hey +test") "hey")
(test (remove-project "hey +test sdfsdf") "hey sdfsdf")

(defn remove-note [text]
  (->> text
       (peg/replace ~(sequence " note:" (thru (* :w+ ".md"))) "")
       (string)))

(test (remove-note "hey sdfsdf note:sdf.md") "hey sdfsdf")
(test (remove-note "hey sdfsdf note:not-a-markdown-file") "hey sdfsdf note:not-a-markdown-file")
(test (-> "todo with note and project note:eeb055e1.md +test"
          (remove-project)
          (remove-note))
  "todo with note and project")

(defn normalize-text [text]
  (->> text
       (remove-project)
       (remove-note)
       (string/replace-all "\r" " ")
       (string/replace-all "\n" " ")
       string/trim))

(defn truncate-text [text]
  (if (<= (length text) max-length)
    text
    (string (string/slice text 0 (- max-length (length ellipsis))) ellipsis)))

(test (find-priority-a-task "(A) High priority task") "High priority task")

(test (find-priority-a-task "x done task\n(B) low prio\n(A) first a task\n(A) second a task") "first a task")

(test (find-priority-a-task "(B) not A priority") nil)

(test (find-priority-a-task nil) nil)

(test (find-priority-a-tasks "(A) one\n(A) two\n(B) three") @["one" "two"])

(test (find-priority-a-tasks "(B) none") @[])

(test (find-priority-a-tasks nil) nil)

(test (truncate-text (normalize-text "line 1\nline 2")) "line 1 line 2")

(defn main [& args]
  (let [tasks (try
                (-> todo-path read-from-file find-priority-a-tasks)
                ([err] nil))
        first-task (first (or tasks []))
        n (length (or tasks []))]
    (when first-task
      (let [body (-> first-task normalize-text truncate-text)
            badge (if (> n 1)
                    (string "#[fg=colour15,bg=colour1] [" n "] ")
                    "")]
        (prin (string badge
                      "#[fg=colour0,bg=colour14] " body
                      " #[fg=default,bg=default]"))))))
