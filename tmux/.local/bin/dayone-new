#!/usr/bin/env bash
set -euo pipefail

file="$HOME/wikis/vimwiki/Inbox/dayone-$(date +%Y-%m-%d-%H%M%S).md"

nvim "$file"

if [ -s "$file" ]; then
  encoded=$(python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read()))" < "$file")
  open "dayone://post?entry=${encoded}"
else
  echo "Empty file, skipping."
  rm -f "$file"
fi
