#!/usr/bin/env bash
set -euo pipefail

tmp=$(mktemp /tmp/dayone-XXXXXX.md)
trap 'rm -f "$tmp"' EXIT

nvim "$tmp"

if [ -s "$tmp" ]; then
  encoded=$(python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read()))" < "$tmp")
  open "dayone://post?entry=${encoded}"
else
  echo "Empty file, skipping."
fi
