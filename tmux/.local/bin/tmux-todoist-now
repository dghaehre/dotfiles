#!/usr/bin/env janet

(use judge)

(def max-length 48)
(def ellipsis "...")
(def cache-ttl 60)
(def cache-path (string (os/getenv "HOME") "/.cache/todoist-now"))

(defn read-from-file [file-path]
  (let [f (file/open file-path :r)
        content (file/read f :all)]
    (file/close f)
    content))

(defn read-token []
  (let [path (string (os/getenv "HOME") "/.todoist.token")]
    (try
      (let [token (-> (read-from-file path) string/trim)]
        (if (= "" token) nil token))
      ([err] nil))))

(defn most-likely-failure [out]
  (string/has-prefix? "curl:" (string/trim out)))

(defn fetch-now-task [token]
  (let [[stdout-r stdout-w] (os/pipe)]
    (defer
      (do
        (:close stdout-r)
        (:close stdout-w))
      (let [status (os/execute
                     ["/bin/sh"
                      "-c"
                      "/usr/bin/curl -sSf -X GET \"https://api.todoist.com/api/v1/tasks?label=now\" -H \"Authorization: Bearer $TODOIST_TOKEN\" | /opt/homebrew/bin/jq -r '.results[0].content // empty'"]
                     :ep
                     {"TODOIST_TOKEN" token :out stdout-w :err :out})
            _ (:close stdout-w)
            out (:read stdout-r math/int32-max)]
        (when (zero? status)
          (when (not (most-likely-failure out))
            (let [result (-> out string string/trim)]
              (when (not= "" result) result))))))))

(defn normalize-text [text]
  (->> text
      (string/replace-all "\r" " ")
      (string/replace-all "\n" " ")
      string/trim))

(defn truncate-text [text]
  (if (<= (length text) max-length)
    text
    (string (string/slice text 0 (- max-length (length ellipsis))) ellipsis)))

(test (most-likely-failure "curl: (6) Could not resolve host") true)
(test (most-likely-failure "Buy milk") false)
(test (most-likely-failure "") false)

(test (normalize-text "line 1\nline 2") "line 1 line 2")
(test (normalize-text "  trimmed  ") "trimmed")
(test (normalize-text "carriage\rreturn") "carriage return")

(test (truncate-text "short") "short")
(test (truncate-text (normalize-text "sdfsdf sdfsdf ")) "sdfsdf sdfsdf")
(test (truncate-text (string/repeat "a" 50)) (string (string/repeat "a" 45) "..."))

(defn get-cached-task []
  (try
    (when-let [stat (os/stat cache-path)]
      (when (< (- (os/time) (stat :modified)) cache-ttl)
        (string/trim (read-from-file cache-path))))
    ([err] nil)))

(defn write-cache [content]
  (try
    (let [f (file/open cache-path :w)]
      (file/write f (or content ""))
      (file/close f))
    ([err] nil)))

(defn format-output [task]
  (string "#[fg=colour0,bg=colour14] " task " #[fg=default,bg=default]"))

(defn fetch-and-cache [token]
  (try
    (let [result (fetch-now-task token)
          task (when result (-> result normalize-text truncate-text))]
      (write-cache task)
      task)
    ([err] nil)))

(defn main [& args]
  (let [task (or (get-cached-task)
                 (when-let [token (read-token)]
                   (fetch-and-cache token)))]
    (when (and task (not= "" task))
      (prin (format-output task)))))
